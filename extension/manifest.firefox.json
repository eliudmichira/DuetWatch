{
  "manifest_version": 3,
  "name": "Duet",
  "version": "1.2.0",
  "description": "Watch in duet. One remote, two screens — pause and play together from anywhere.",

  "browser_specific_settings": {
    "gecko": {
      "id": "duet@eliudmichira.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "personalCommunications",
          "browsingActivity"
        ],
        "optional": [
          "authenticationInfo"
        ]
      }
    }
  },

  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "scripts": [
      "vendor/firebase-app-compat.js",
      "vendor/firebase-database-compat.js",
      "background.js"
    ],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
