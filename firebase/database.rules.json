{
  "rules": {
    "rooms": {
      ".read": false,
      ".write": false,

      "$roomId": {
        ".read":  "$roomId.length === 6",
        ".write": "$roomId.length === 6",

        "state": {
          ".validate": "newData.hasChildren(['action','currentTime','updatedBy'])",

          ".write": "$roomId.length === 6 && (
            !data.exists() ||
            !data.child('serverTime').exists() ||
            (now - data.child('serverTime').val()) > 75
          )",

          "action":       { ".validate": "newData.isString() && (newData.val() === 'play' || newData.val() === 'pause')" },
          "currentTime":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 86400" },
          "playbackRate": { ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() < 16" },
          "updatedBy":    { ".validate": "newData.isString() && newData.val().length <= 32" },
          "serverTime":   { ".validate": "newData.isNumber()" },
          "force":        { ".validate": "newData.isBoolean()" },
          "$other":       { ".validate": false }
        },

        "meta": {
          "$userId": {
            ".write": "auth == null && $userId.length <= 32",

            "name":        { ".validate": "newData.isString() && newData.val().length <= 32" },
            "url":         { ".validate": "newData.isString() && newData.val().length <= 1024" },
            "hostname":    { ".validate": "newData.isString() && newData.val().length <= 253" },
            "pageTitle":   { ".validate": "newData.isString() && newData.val().length <= 256" },
            "videoTitle":  { ".validate": "newData.isString() && newData.val().length <= 256" },
            "duration":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 86400" },
            "currentTime": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() < 86400" },
            "paused":      { ".validate": "newData.isBoolean()" },
            "lastSeen":    { ".validate": "newData.isNumber()" },
            "emoji":       { ".validate": "newData.isString() && newData.val().length <= 16" },
            "$other":      { ".validate": false }
          }
        },

        "reactions": {
          "$reactionId": {
            ".validate": "newData.hasChildren(['emoji','from','ts'])",
            "emoji": { ".validate": "newData.isString() && newData.val().length <= 140" },
            "from":  { ".validate": "newData.isString() && newData.val().length <= 32" },
            "ts":    { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },

        "together": {
          "since": { ".validate": "newData.isNumber() || newData.val() == null" },
          "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "$other": { ".validate": false }
        },

        "host":      { ".validate": "newData.isString() && newData.val().length <= 32" },
        "created":   { ".validate": "newData.isNumber()" },
        "lastTouch": { ".validate": "newData.isNumber()" },

        "$other": { ".validate": false }
      }
    },

    "presence": {
      ".read": false,
      ".write": false,
      "$roomId": {
        ".read":  "$roomId.length === 6",
        ".write": "$roomId.length === 6",
        "$userId": {
          ".validate": "$userId.length <= 32",
          "joined": { ".validate": "newData.isNumber()" },
          "$other": { ".validate": false }
        }
      }
    }
  }
}
